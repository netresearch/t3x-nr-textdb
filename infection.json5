{
    "$schema": "https://raw.githubusercontent.com/infection/infection/0.29.0/resources/schema.json",
    "source": {
        "directories": [
            "Classes"
        ]
    },
    "logs": {
        "text": ".build/infection.log"
    },
    "phpUnit": {
        "configDir": "Build",
        "customPath": ".build/bin/phpunit"
    },
    "mutators": {
        "@default": true
    },
    "minMsi": 30,
    "minCoveredMsi": 60
}
